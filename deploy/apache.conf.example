# Apache vhost for BharatPaye (Laravel 12) — use this instead of nginx.conf.example
# if the VPS is running Apache + mod_php or Apache + PHP-FPM via mod_proxy_fcgi.
#
# 1. Copy to /etc/apache2/sites-available/bharatpaye.conf
# 2. Replace yourdomain.com
# 3. Enable required modules: a2enmod rewrite proxy_fcgi setenvif headers
# 4. Enable the site: a2ensite bharatpaye.conf && systemctl reload apache2
# 5. Run certbot --apache afterwards to add HTTPS (see deploy/DEPLOYMENT.md)

<VirtualHost *:80>
    ServerName yourdomain.com
    ServerAlias www.yourdomain.com
    DocumentRoot /var/www/bharatpaye/public

    <Directory /var/www/bharatpaye/public>
        Options -Indexes +FollowSymLinks
        AllowOverride All
        Require all granted
    </Directory>

    <FilesMatch \.php$>
        SetHandler "proxy:unix:/run/php/php8.3-fpm.sock|fcgi://localhost"
    </FilesMatch>

    <DirectoryMatch "^/var/www/bharatpaye/(?!public/)">
        Require all denied
    </DirectoryMatch>

    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"

    ErrorLog ${APACHE_LOG_DIR}/bharatpaye-error.log
    CustomLog ${APACHE_LOG_DIR}/bharatpaye-access.log combined
</VirtualHost>
